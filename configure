#!/bin/sh

set -eu

use_cuda=${FASTEMBEDR_USE_CUDA:-auto}
cuda_home=${CUDA_HOME:-}
nvcc=${NVCC:-}
if [ -z "$nvcc" ]; then
  if [ -n "$cuda_home" ] && [ -x "$cuda_home/bin/nvcc" ]; then
    nvcc="$cuda_home/bin/nvcc"
  else
    nvcc=$(command -v nvcc 2>/dev/null || true)
  fi
fi

if [ -z "$cuda_home" ] && [ -n "$nvcc" ]; then
  cuda_bin=$(dirname "$nvcc")
  cuda_home=$(dirname "$cuda_bin")
fi

if [ "$use_cuda" = "1" ] && [ -z "$nvcc" ]; then
  echo "FASTEMBEDR_USE_CUDA=1 was requested, but nvcc was not found." >&2
  echo "Set CUDA_HOME or NVCC, or use FASTEMBEDR_USE_CUDA=0 for a non-CUDA build." >&2
  exit 1
fi

if [ "$use_cuda" = "1" ] && [ -z "$cuda_home" ]; then
  echo "FASTEMBEDR_USE_CUDA=1 was requested, but CUDA_HOME could not be resolved." >&2
  echo "Set CUDA_HOME to the CUDA toolkit root." >&2
  exit 1
fi

os_name=$(uname -s 2>/dev/null || echo unknown)

metal_objects="embedding_metal_bridge.o embedding_metal_stub.o"
cppflags=""
libs="-pthread"

if [ "$os_name" = "Darwin" ]; then
  metal_objects="embedding_metal_bridge.o embedding_metal_impl.o"
  cppflags="-DHAVE_METAL=1"
  libs="-pthread -framework Foundation -framework Metal -framework MetalPerformanceShaders -framework MetalPerformanceShadersGraph"
fi

cuda_objects="embedding_cuda_stub.o"
cuda_rule=""
if [ "$use_cuda" != "0" ] && [ -n "$nvcc" ] && [ -n "$cuda_home" ]; then
  cuda_include_flags="-I$cuda_home/include"
  cuda_lib_flags="-L$cuda_home/lib64 -L$cuda_home/lib"
  if [ -d "$cuda_home/targets/x86_64-linux/include" ]; then
    cuda_include_flags="$cuda_include_flags -I$cuda_home/targets/x86_64-linux/include"
  fi
  if [ -d "$cuda_home/targets/x86_64-linux/lib" ]; then
    cuda_lib_flags="$cuda_lib_flags -L$cuda_home/targets/x86_64-linux/lib"
  fi
  cuda_arch_flags=""
  for arch in ${FASTEMBEDR_CUDA_ARCH:-}; do
    cuda_arch_flags="$cuda_arch_flags -gencode=arch=compute_$arch,code=sm_$arch"
  done
  cuda_extra_flags=${FASTEMBEDR_CUDA_FLAGS:-}
  cuda_objects="embedding_cuda_impl.o embedding_cuda_kernels.o"
  cppflags="$cppflags -DFASTEMBEDR_HAS_CUDA $cuda_include_flags"
  libs="$libs $cuda_lib_flags -lcudart -lcufft"
  cuda_rule="
.DEFAULT_GOAL := all

CUDA_NVCCFLAGS = -std=c++14 -x cu -Xcompiler -fPIC $cuda_include_flags$cuda_arch_flags $cuda_extra_flags

embedding_cuda_kernels.o: embedding_cuda_kernels.cpp
	\$(NVCC) \$(CUDA_NVCCFLAGS) -c \$< -o \$@
"
fi

{
  echo "CXX_STD = CXX17"
  echo "PKG_CXXFLAGS = -pthread"
  if [ -n "$cppflags" ]; then
    echo "PKG_CPPFLAGS = $cppflags"
  fi
  echo "PKG_LIBS = $libs"
  if [ "$cuda_objects" != "embedding_cuda_stub.o" ]; then
    echo "NVCC = $nvcc"
    printf "%s" "$cuda_rule"
  fi
  echo "OBJECTS = RcppExports.o tsne_neighbors.o embedding_utils.o fast_knn_umap.o $metal_objects embedding_cuda_bridge.o $cuda_objects"
} > src/Makevars
