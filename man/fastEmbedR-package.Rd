\name{fastEmbedR-package}
\alias{fastEmbedR-package}
\docType{package}
\title{fastEmbedR: Fast UMAP From KNN}
\description{
Fast UMAP from precomputed nearest-neighbour matrices. The package currently
focuses on native exact KNN, UMAP from KNN, one-call UMAP, supervised UMAP,
embedding evaluation, and explicit backend detection.
}
