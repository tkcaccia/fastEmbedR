Bootstrap: docker
From: mambaorg/micromamba:2.3.3

%labels
    Author tkcaccia
    Project fastEmbedR
    Description R + FAISS/cuVS + CUDA container for fastEmbedR UMAP/openTSNE benchmarks

%environment
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH=/opt/conda/bin:/opt/fit-sne/bin:$PATH
    export CONDA_PREFIX=/opt/conda
    export CUDA_HOME=/opt/conda
    export FAISS_HOME=/opt/conda
    export CUVS_HOME=/opt/conda
    export FASTEMBEDR_USE_CUDA=1
    export FASTEMBEDR_CUDA_FLAGS="-I/opt/conda/targets/x86_64-linux/include ${FASTEMBEDR_CUDA_FLAGS:-}"
    export FAISSR_USE_FAISS=1
    export FAISSR_USE_CUDA=1
    export FAISSR_USE_CUVS=1
    export LD_LIBRARY_PATH=/opt/conda/lib:/opt/conda/targets/x86_64-linux/lib:$LD_LIBRARY_PATH
    export CPATH=/opt/conda/include:/opt/conda/targets/x86_64-linux/include:$CPATH
    export LIBRARY_PATH=/opt/conda/lib:/opt/conda/targets/x86_64-linux/lib:$LIBRARY_PATH
    export PKG_CPPFLAGS="-I/opt/conda/include -I/opt/conda/targets/x86_64-linux/include ${PKG_CPPFLAGS:-}"
    export PKG_LIBS="-L/opt/conda/lib -L/opt/conda/targets/x86_64-linux/lib ${PKG_LIBS:-}"
    export CUDAHOSTCXX=/opt/conda/bin/g++
    export OMP_NUM_THREADS=${OMP_NUM_THREADS:-4}
    export OPENBLAS_NUM_THREADS=${OPENBLAS_NUM_THREADS:-4}
    export MKL_NUM_THREADS=${MKL_NUM_THREADS:-4}

%post
    set -eux
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH=/opt/conda/bin:$PATH

    micromamba install -y -n base \
      -c rapidsai -c pytorch -c nvidia -c conda-forge \
      cuda-version=13.2 \
      cuda-nvcc \
      cuda-cudart-dev \
      cuda-nvrtc \
      libcufft \
      libcufft-dev \
      faiss-gpu-cuvs=1.14.3 \
      libcuvs=26.06 \
      libcuvs-headers=26.06 \
      librmm=26.06 \
      libraft-headers=26.06 \
      r-base \
      r-remotes \
      r-rcpp \
      r-jsonlite \
      r-data.table \
      r-matrix \
      r-ggplot2 \
      r-uwot \
      r-rtsne \
      r-umap \
      r-tsne \
      r-rcppannoy \
      r-irlba \
      r-rspectra \
      r-fnn \
      r-rann \
      r-r.utils \
      r-devtools \
      git \
      make \
      cmake \
      pkg-config \
      fftw \
      gcc_linux-64 \
      gxx_linux-64 \
      gfortran_linux-64

    micromamba clean -a -y

    export CONDA_PREFIX=/opt/conda
    export CUDA_HOME=/opt/conda
    export FAISS_HOME=/opt/conda
    export CUVS_HOME=/opt/conda
    export FASTEMBEDR_USE_CUDA=1
    export FASTEMBEDR_CUDA_FLAGS="-I/opt/conda/targets/x86_64-linux/include ${FASTEMBEDR_CUDA_FLAGS:-}"
    export FAISSR_USE_FAISS=1
    export FAISSR_USE_CUDA=1
    export FAISSR_USE_CUVS=1
    export LD_LIBRARY_PATH=/opt/conda/lib:/opt/conda/targets/x86_64-linux/lib:${LD_LIBRARY_PATH:-}
    export CPATH=/opt/conda/include:/opt/conda/targets/x86_64-linux/include:${CPATH:-}
    export LIBRARY_PATH=/opt/conda/lib:/opt/conda/targets/x86_64-linux/lib:${LIBRARY_PATH:-}
    export PKG_CPPFLAGS="-I/opt/conda/include -I/opt/conda/targets/x86_64-linux/include ${PKG_CPPFLAGS:-}"
    export PKG_LIBS="-L/opt/conda/lib -L/opt/conda/targets/x86_64-linux/lib ${PKG_LIBS:-}"
    export PATH=/opt/conda/bin:$PATH
    export CC=x86_64-conda-linux-gnu-cc
    export CXX=x86_64-conda-linux-gnu-c++
    export FC=x86_64-conda-linux-gnu-gfortran

    ln -sf /opt/conda/bin/x86_64-conda-linux-gnu-cc /opt/conda/bin/gcc
    ln -sf /opt/conda/bin/x86_64-conda-linux-gnu-c++ /opt/conda/bin/g++
    ln -sf /opt/conda/bin/x86_64-conda-linux-gnu-gfortran /opt/conda/bin/gfortran
    export CUDAHOSTCXX=/opt/conda/bin/g++

    Rscript -e "options(repos = c(CRAN = 'https://cloud.r-project.org')); install.packages(c('remotes', 'BiocManager'), Ncpus = 4)"
    Rscript -e "options(repos = c(CRAN = 'https://cloud.r-project.org')); install.packages(c('uwot', 'umap', 'Rtsne', 'tsne', 'FNN', 'RANN', 'RcppAnnoy', 'ggplot2', 'data.table', 'jsonlite'), Ncpus = 4)"

    # KlugerLab/FIt-SNE command-line implementation for benchmark comparison.
    git clone --depth 1 https://github.com/KlugerLab/FIt-SNE /opt/fit-sne-src
    mkdir -p /opt/fit-sne-src/bin /opt/fit-sne/bin
    cd /opt/fit-sne-src
    x86_64-conda-linux-gnu-c++ -std=c++11 -O3 \
      -I/opt/conda/include \
      src/sptree.cpp src/tsne.cpp src/nbodyfft.cpp \
      -o bin/fast_tsne \
      -L/opt/conda/lib -pthread -lfftw3 -lm -Wno-address-of-packed-member
    mkdir -p /opt/fit-sne/bin
    cp /opt/fit-sne-src/bin/fast_tsne /opt/fit-sne/bin/fast_tsne
    cp /opt/fit-sne-src/fast_tsne.R /opt/fit-sne/bin/fast_tsne.R

    Rscript -e "remotes::install_github('tkcaccia/faissR', upgrade = 'never', dependencies = TRUE)"
    Rscript -e "remotes::install_github('tkcaccia/fastEmbedR', upgrade = 'never', dependencies = TRUE)"

    Rscript -e "library(faissR); library(fastEmbedR); print(faissR::backend_info()); print(fastEmbedR::backend_info())"

%runscript
    exec "$@"

%test
    Rscript -e "library(faissR); library(fastEmbedR); stopifnot(faissR::faiss_available()); print(faissR::backend_info()); print(fastEmbedR::backend_info())"
